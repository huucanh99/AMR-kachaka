# Server
PORT=3000

# Kachaka robot gRPC endpoint
# Use mock server: 127.0.0.1:26400
# Use real robot:  <robot-ip>:26400
KACHAKA_HOST=127.0.0.1
KACHAKA_PORT=26400

# SQLite — path to the database file (relative to backEnd/)
# Leave blank to use default: kachaka.db (auto-created next to server.js)
DB_PATH=

# CORS – frontend origin (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173
